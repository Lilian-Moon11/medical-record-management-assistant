#Prevents patient files from getting uploaded to the github/version control
# --- Python & System Junk ---
.venv/
venv/
__pycache__/
*.py[cod]
.DS_Store
.vs/
.gemini_scratch/
test_pack/

# --- Environment Variables ---
.env

# --- Patient Data (CRITICAL SAFETY LOCK) ---
# Database files
*.db
*.db.keybag
*.sqlite
*.sqlite3

# Document Intake & Exports (Phase 2)
*.pdf
*.doc
*.docx
*.xlsx
*.xls
*.csv
*.json
*.enc

# Directory Locks
/data/
/records/
/exports/

# --- Logs ---
*.log
logs/

# --- Build Files (Flet & PyInstaller) ---
dist/
# build/ is kept so build scripts and mrma.spec are version-controlled.
# Only the generated output inside build/ is ignored:
build/windows/
build/macos/
build/linux/
build/flutter/
build/site-packages/
build/mrma/
build/*.pkg
build/*.exe